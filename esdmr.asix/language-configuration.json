{
    "comments": {
        "lineComment": "// "
    },
    "wordPattern": "[^\\s/]+",
		"autoClosingPairs": [
			[
				"(",
				")"
			]
		],
		"surroundingPairs": [
			[
				"(",
				")"
			]
		],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(?:if|fn)",
        "decreaseIndentPattern": "^\\s*(?:fi|nf)"
    },
    "colorizedBracketPairs": [
        [
            "if",
            "fi"
        ]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*//\\s*#region",
            "end": "^\\s*//\\s*#endregion"
        }
    }
}
